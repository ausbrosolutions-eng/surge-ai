# ═══════════════════════════════════════════════════════════════
# Surge Advisory - Production Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# This file documents every env var the app needs in production.
# Copy the KEYS into Vercel → Project Settings → Environment Variables.
# DO NOT commit actual values to git. This file is a template only.
#
# Quick setup sequence:
#   1. Set SURGE_ACCESS_PASSWORD (required - locks internal routes)
#   2. Confirm Supabase vars match your existing project
#   3. Add integration keys as you wire up each one (optional at launch)
# ═══════════════════════════════════════════════════════════════


# ── REQUIRED: Access control ───────────────────────────────────
# Password for /surge/*, /platform/*, /dashboard/*
# Choose something you'd share with clients (Scott, Aaron) when they
# need to log into their platform. Rotate by changing this value.
SURGE_ACCESS_PASSWORD=


# ── Supabase (existing marketing site data layer) ─────────────
# These already exist in your .env.local - copy them over.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ── Email delivery (Phase 4 weekly digests) ───────────────────
# Recommended: Resend ($20/mo, 50K emails). Alternative: SendGrid.
# When set, the "Send to Owner" button on reports page will actually
# send to Scott's inbox. Until then, mock mode is active.
RESEND_API_KEY=
RESEND_FROM_EMAIL=austin@surgeadvisory.co


# ── JobNimbus API (for Rehab Restoration live sync) ───────────
# Key "AI Business Analysis" already created in Rehab's JN account.
# Ask Scott to share it when ready for live sync.
JN_API_KEY=


# ── Encircle API (future - when partnership signed) ───────────
# Requires partner agreement with getencircle.com first.
ENCIRCLE_API_KEY=
ENCIRCLE_COMPANY_ID=


# ── Twilio (future - SMS automation) ──────────────────────────
# For collection SMS sequences, customer milestone updates.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ── Stripe (future - Ops Audit payments) ──────────────────────
# When you productize the $3,500 audit with a payment link.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ── Analytics (recommended) ───────────────────────────────────
# Vercel Analytics is free, one-click on dashboard.
# If you want more detail, add Posthog or Plausible.
POSTHOG_API_KEY=


# ═══════════════════════════════════════════════════════════════
# Deployment notes
# ═══════════════════════════════════════════════════════════════
#
# In Vercel dashboard:
#   - Set these under Settings → Environment Variables
#   - Scope: "Production" only (keep previews off unless you want
#     preview deploys accessible via same password)
#   - NEVER paste values into code or commit this file with values
#
# After setting env vars, redeploy so they take effect.
# ═══════════════════════════════════════════════════════════════
